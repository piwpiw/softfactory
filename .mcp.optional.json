{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "description": "On-demand repository issue/PR operations"
    },
    "google-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-search"],
      "description": "On-demand market research and web lookup fallback"
    },
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "On-demand browser automation and screenshot checks"
    },
    "claude": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-anthropic"],
      "description": "Optional AI delegation and reasoning server"
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "--database-url", "env:DATABASE_URL"],
      "description": "Optional production DB operations"
    }
  }
}
