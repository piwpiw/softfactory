                                       200
                                   ],
                      "parameters":  {
                                         "jsCode":  "const events = $input.first().json.events || []; if (!events.length) { return [{ json: { skipped: true } }]; } const first = events[0]; return [{ json: { ...first, skipped: false } }];"
                                     }
                  },
